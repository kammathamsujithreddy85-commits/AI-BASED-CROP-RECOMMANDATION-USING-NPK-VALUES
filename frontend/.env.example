# ==================== FRONTEND ENVIRONMENT TEMPLATE ====================
# Copy to .env.local (dev, Git-ignored) or set in Vercel dashboard (prod)

# ==================== API ENDPOINT ====================
VITE_API_URL=http://localhost:5000
# Local dev: http://localhost:5000
# Production (Render): https://cropai-api.onrender.com
# You MUST update this for production builds

# ==================== BUILD ENVIRONMENT ====================
VITE_NODE_ENV=development
# development | production
# Automatically set by Vite during build

# ==================== OPTIONAL: Analytics ====================
# VITE_ANALYTICS_KEY=your-analytics-key
# For future: add Vercel Analytics or Sentry
