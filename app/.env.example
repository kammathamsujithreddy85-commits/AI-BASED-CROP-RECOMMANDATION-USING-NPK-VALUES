# ==================== ENVIRONMENT TEMPLATE ====================
# Copy this file to .env (local dev) or set in deployment platform
# NEVER commit actual .env file to Git (use .env.example for docs)

# ==================== FLASK CONFIGURATION ====================
FLASK_ENV=development
# On Render: FLASK_ENV=production

FLASK_SECRET_KEY=your-secret-key-here-min-32-chars-random
# Generate: python -c "import secrets; print(secrets.token_hex(32))"

# ==================== GROQ API (LLM Backend) ====================
GROQ_API_KEY=gsk_your_groq_api_key_here
# Get from: https://console.groq.com
# Use llama-3.1-8b-instant (free model)

GROQ_MODEL=llama-3.1-8b-instant
# Available: llama-3.1-8b-instant, llama-3.1-70b-versatile, etc.

GROQ_TIMEOUT=30
# Request timeout in seconds (default: 30)

# ==================== CORS CONFIGURATION ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# On Vercel: ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app
# Comma-separated, no spaces

# ==================== EXTERNAL APIs ====================
AGMARKNET_API_URL=https://agmarknet.gov.in/Api1.0/prices
# Agricultural market data API (optional)

REQUEST_TIMEOUT=10
# Timeout for external API calls in seconds

# ==================== FILE UPLOADS ====================
MAX_CONTENT_LENGTH=16777216
# Max upload size in bytes (16MB default)

# ==================== LOGGING ====================
LOG_LEVEL=DEBUG
# DEV: DEBUG, PROD: INFO

LOG_FILE=app/logs/app.log
# Log file path (created automatically)

# ==================== DATABASE (FUTURE) ====================
# DATABASE_URL=postgresql://user:password@localhost:5432/cropai
# Use Supabase or Neon for production

# ==================== DEPLOYMENT PLATFORMS ====================
# Render:  https://render.com
#   - Set these vars in Render Dashboard → Environment
#   - No need for .env file (it's ignored in production)

# Vercel (Frontend only):
#   - Create .env.production in frontend/ directory
#   - Set: VITE_API_URL=https://your-render-backend-url
